#postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=luffy
POSTGRES_DB=smartdocs_db
DATABASE_URL=postgresql+asyncpg://postgres:luffy@localhost:5432/smartdocs_db

#Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=another-secret-key-for-jwt-tokens-change-this-too
