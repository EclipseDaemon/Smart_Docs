ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

DEBUG=True
APP_NAME=SmartDocs
APP_VERSION=1.0.0
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars